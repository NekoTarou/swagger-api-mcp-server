# Swagger/OpenAPI spec URL (auto-loaded on startup if provided)
SWAGGER_URL=

# Transport mode: "stdio" (default) or "http"
TRANSPORT=stdio

# HTTP server configuration (only used when TRANSPORT=http)
MCP_PORT=3000
MCP_HOST=0.0.0.0

# API base URL override (if different from spec)
API_BASE_URL=

# API authentication header (e.g. "Bearer your-token" or "Basic base64-encoded")
API_AUTH_TOKEN=

# Cache directory for parsed spec data (default: .swagger-cache)
CACHE_DIR=

# Session management (HTTP mode)
SESSION_TIMEOUT_MS=1800000
MAX_SESSIONS=100
SESSION_CLEANUP_INTERVAL_MS=60000
ENABLE_SESSION_DEBUG=false
